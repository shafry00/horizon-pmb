model User {
  id        String   @id @default(uuid())
  name      String 
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime

  user User @relation(references: [id], fields: [userId], onDelete: Cascade)
  @@index([userId]) 
}
